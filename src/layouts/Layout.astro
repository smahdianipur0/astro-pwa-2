    <title>{title}</title>
    <script is:inline > if (typeof navigator.serviceWorker !== 'undefined') {navigator.serviceWorker.register('sw.js')}</script>

	</head>
  
  <body class="ZStack" 
  style=" overscroll-behavior: none;
  background: oklch(var(--gray-10));
  height: 100dvh;
  transition: color .2s ease-out">

    <slot/>

    <div class="bottom x-stretch gradient-blur" id="nav-gradient-blur"></div>

    <BottomNav/>
    <Toast/>

  </body>


</html>

<style is:global>


#nav-gradient-blur{
  transform: scaleY(-1);
}

@media only screen and (min-width: 450px) {
  #nav-gradient-blur{
    align-self: start;;
    transform: initial;
  }
}

</style>