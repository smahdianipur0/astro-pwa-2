---
import Drawer from '../components/ui/Drawer.tsx';
---

<div class="ZStack"style="margin-bottom: var(--size-md2); width: min(100%, var(--size-xl7));">
    <menu>
        <li>
    <Drawer id='RecentDelPass' direction='right'>

        <fragment slot="trigger" class="prose"> 

                <div class="HStack" 
                    style="line-height: var(--size-sm4);
                    color: white;">
                    <div>Recently Deleted</div>
                    <div style="flex: 1;"></div>
                    <svg style="padding: 2px" width="24" height="24" fill="none" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path d="M8.293 4.293a1 1 0 0 0 0 1.414L14.586 12l-6.293 6.293a1 1 0 1 0 1.414 1.414l7-7a1 1 0 0 0 0-1.414l-7-7a1 1 0 0 0-1.414 0Z" fill="oklch(var(--gray-95) / 0.5)"/></svg>
                </div>

        </fragment>

        <fragment slot="title" style="font-weight: 500;">Recently Deleted</fragment>

        <Fragment slot="content" class="prose" >

                <fieldset 
                    class="box-shadow" 
                    style="padding: 0; color: oklch(var(--gray-95));">

                    <menu id="RecentDelPass-list" style="background: transparent;">
                        <small style="padding-block: var(--size-sm3);">No records found</small>
                    </menu>

                </fieldset>

            <dialog id="RecentDelPass-restore">
                <form method="dialog">           

                    <h3 style="margin-top: 0;">Restore Item</h3>

                    <div 
                        id="RecentDelPass-restore-item"
                        style="display: flex;
                        flex-direction: column;
                        align-items: flex-start;
                        background: oklch(var(--gray-10) / 20%);
                        border-radius: var(--radius-s);
                        padding: var(--size-sm1);"></div>

                    <div class="HStack" style="margin-top:var(--size-sm3);">
                      
                      <button style="width: var(--stretch);" class="not-prose max-width" >Cancel</button>
                      <button style="width: var(--stretch);" id="RecentDelPass-restore-ok">Restore</button>
                  
                    </div>
                </form>
            </dialog>
        </Fragment>
    </Drawer>
    </li>
    </menu>
        
</div>


<script>

import { dbCreate, dbDelete, getEntryById, toRecordId } from "../utils/surrealdb-indexed";
import { showToast } from "../logic/misc";
import { tempList } from "../logic/tempList.ts" 
import { render } from "solid-js/web"
import { List, dialog} from './RecentDelPass'
import { initDrawer } from "./ui/drawer"


initDrawer("RecentDelPass");

tempList.updateRecentDelEntries();

const recentdellist = document.getElementById("RecentDelPass-list")   as HTMLElement;

tempList.on(["recentDelEntries"], ({value}) => {
    recentdellist.textContent = '';

    if (value.length === 0){
        render(() => List(), recentdellist);
    } else {
        (value ?? [])
        .sort((a, b) => new Date(b.createdAt).getTime() - new Date(a.createdAt).getTime())
        .forEach((entry) => {
            render(() => List(entry), recentdellist);
        });
    }
});


recentdellist.addEventListener("click", (e) => {
    // copy
    const copyButton = (e!.target as HTMLInputElement).closest("[data-action='copy']");
    if (copyButton) {
      (async () => {
        navigator.clipboard.writeText(copyButton.id);  
         showToast();
      })();
    }

    // delete
    const deleteButton = (e!.target as HTMLInputElement).closest("[data-action='delete']");
    if (deleteButton) {
        const buttonId = toRecordId(deleteButton.id,`RecentDelPass`);
        (async () => { buttonId && tempList.deleteRecentDelEntris(buttonId)})();
    }


    // restore
    const restoreButton = (e!.target as HTMLInputElement).closest("[data-action='restore']");
    if (restoreButton) {
      (async() => {
        (document.getElementById("RecentDelPass-restore") as HTMLDialogElement).showModal();
        const buttonId = toRecordId((restoreButton.id), "RecentDelPass");
        const entry = buttonId ? await getEntryById(buttonId): undefined;  

        (document.getElementById("RecentDelPass-restore-item") as HTMLDialogElement).textContent = "";
        render(() => dialog(entry), document.getElementById("RecentDelPass-restore-item") as HTMLDialogElement);

      })();   
    }
});

//confirm restore
document.getElementById("RecentDelPass-restore")!.addEventListener("click", (e) => {
if((e!.target as HTMLInputElement).matches("#RecentDelPass-restore-ok")) {
  (async () => {

  const title = document.getElementById("RecentDelPass-restore-item")?.children[0].textContent;
  const createdAt = document.getElementById("RecentDelPass-restore-item")?.children[0].id ;

  const id = document.getElementById("RecentDelPass-restore-item")?.children[1].id;
  const password = document.getElementById("RecentDelPass-restore-item")?.children[1].textContent;


    if (title && password) {
      await dbCreate("PasswordEntry:create", {title:title, password:password, createdAt: createdAt ?? ""  });
      tempList.updateEntries();

      const rid = toRecordId(id ?? '');
      rid && await dbDelete(rid);
      tempList.updateRecentDelEntries();
    }
  })();
}
});

</script>