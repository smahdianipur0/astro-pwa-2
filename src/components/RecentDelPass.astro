---
import Drawer from '../components/ui/Drawer.tsx';
---

<div class="max-width flex-center-childs"style="margin-bottom: var(--size-md2);">
    <Drawer id='RecentDelPass' direction='right'>

        <fragment slot="trigger" class="prose"> 
            <menu>
                <li class="flex-spread-childs" 
                    style="border-radius: var(--radius-s);
                    margin-inline: auto;
                    line-height: var(--size-sm4);
                    width: min( calc(100cqw - (var(--size-sm1) * 2)) , var(--size-xl7));
                    color: white;
                    padding: var(--padding-4);
                    background-color: oklch(var(--gray-15) / 75%);">
                    <div>Recently Deleted</div>
                    <svg style="padding: 2px" width="24" height="24" fill="none" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path d="M8.293 4.293a1 1 0 0 0 0 1.414L14.586 12l-6.293 6.293a1 1 0 1 0 1.414 1.414l7-7a1 1 0 0 0 0-1.414l-7-7a1 1 0 0 0-1.414 0Z" fill="oklch(var(--gray-95) / 0.5)"/></svg>
                </li>
            </menu>
        </fragment>

        <fragment slot="title" style="font-weight: 500;">Recently Deleted</fragment>

        <Fragment slot="content" class="prose" >

                <fieldset 
                    class="box-shadow" 
                    style="padding: 0; color: oklch(var(--gray-95));">

                    <menu id="RecentDelPass-list">
                        <small style="padding-block: var(--size-sm3);">No records found</small>
                    </menu>

                </fieldset>

            <dialog id="RecentDelPass-restore">
                <form method="dialog">           

                    <h3 style="margin-top: 0;">Restore Item</h3>

                    <div 
                        id="RecentDelPass-restore-item"
                        style="display: flex;
                        flex-direction: column;
                        align-items: flex-start;
                        background: oklch(var(--gray-10) / 20%);
                        border-radius: var(--radius-s);
                        padding: var(--size-sm1);"></div>

                    <div 
                        class="flex-center-childs" 
                        style="gap:var(--size-sm0);
                        margin-top:var(--size-sm3);">
                      
                      <button class="not-prose max-width" >Cancel</button>
                      <button class="max-width" id="RecentDelPass-restore-ok">Restore</button>
                  
                    </div>
                </form>
            </dialog>
        </Fragment>
    </Drawer>
</div>


<script>

    import { initDrawer } from "./ui/drawer"
    initDrawer("RecentDelPass");

</script>
