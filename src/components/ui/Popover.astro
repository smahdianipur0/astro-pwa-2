---
import { customAlphabet } from 'nanoid';

const firstChar = customAlphabet(
  'ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz',
  1,
);
const restChars = customAlphabet(
  'ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789',
  5,
);

const id         = firstChar() + restChars();
const anchorName = `--${id}`;  
---

<button popovertarget={id} 
    style={`anchor-name: ${anchorName}; cursor: pointer;`}
    class="not-prose">
    <slot name="trigger"/>
</button>


<div class=" prose popover-panel subtle-shadow" 
    id={id} popover="auto" 
    style={`position-anchor: ${anchorName}`}>
    <slot />
</div>

<style>

  .popover-panel {
    padding: 0;
    position: fixed;
    position-area: bottom;
    position-try-fallbacks:
      flip-block,
      flip-inline,
      flip-block flip-inline;
    min-width: anchor-size(width);
    opacity: 0;
    scale: 0.8;
    transform-origin: top center;
    transition:
      opacity 250ms cubic-bezier(0.6, 1.45, 0.5, 1),
      scale   250ms cubic-bezier(0.6, 1.45, 0.5, 1),
      display 250ms allow-discrete,
      overlay 250ms allow-discrete;
  }


  .popover-panel:popover-open {
    opacity: 1;
    scale: 1;
  }

  @starting-style {
    .popover-panel:popover-open {
      opacity: 0;
      scale: 0.8;
    }
  }
</style>
